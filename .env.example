NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — nur für Webhook-Schreibzugriff, falls security-definer-RPC
# nicht reicht. Empfohlen für Production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Billing — sandbox vs. live wird allein über das Key-Prefix
# (sk_test_... / sk_live_...) gesteuert. Webhook-Secret pro Endpoint.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Tiered-Pricing-Price-ID. In Stripe ein Produkt mit Tiered-Pricing
# anlegen (1=0€, 2-5=39,99€, 6-10=49,99€, 11-25=99,99€, 26+=149,99€)
# und hier die Price-ID (Format: price_...) eintragen.
STRIPE_TIERED_PRICE_ID=price_...

# Optional — wird in Stripe-Checkout-/Portal-Return-URLs verwendet.
# Im Dev kann das fehlen; dann wird die Request-Origin genutzt.
NEXT_PUBLIC_APP_URL=https://app.example.com

# -----------------------------------------------------------------
# Stripe Connect
# -----------------------------------------------------------------
# Webhook-Secret für V2-Account-Updates (Thin Events). Aus dem Stripe-
# Dashboard unter Developers → Webhooks → dein Thin-Endpoint kopieren.
# Im Dev: `stripe listen --thin-events '...' --forward-thin-to ...`
STRIPE_WEBHOOK_SECRET_THIN=whsec_...

# Webhook-Secret für klassische Snapshot-Events (Subscription-Lifecycle
# der Plattform-Subscription, Invoices, Payment-Methods etc.).
STRIPE_WEBHOOK_SECRET_CONNECT_SNAPSHOT=whsec_...

# Plattform-Subscription-Preis-ID (Format: price_...). Lege im Stripe-
# Dashboard ein recurring Produkt + Preis an und trage die Price-ID hier
# ein. Wird vom /api/connect/subscription/create-Endpoint verwendet.
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID=price_...

# Optional: Plattform-Gebühr in Basispunkten (100 = 1 %). Default: 200 (2 %).
# Wird bei Direct-Charges (storefront) als application_fee_amount abgezogen.
# STRIPE_PLATFORM_FEE_BPS=200

# Optional: Default-Land für neue Connected Accounts (ISO-2). Default: DE.
# CONNECT_DEFAULT_COUNTRY=DE
